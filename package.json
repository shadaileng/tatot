    "deploy:cf": "pnpm build:h5 && wrangler pages deploy dist/build/h5"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5010220260604001",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-5010220260604001",
    "@dcloudio/uni-components": "3.0.0-alpha-5010220260604001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5010220260604001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5010220260604001",
    "html2canvas": "^1.4.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.11"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-alpha-5010220260604001",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5010220260604001",
    "@dcloudio/uni-stacktracey": "3.0.0-alpha-5010220260604001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5010220260604001",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "sass": "^1.71.1",
    "tailwindcss": "^3.4.19",
